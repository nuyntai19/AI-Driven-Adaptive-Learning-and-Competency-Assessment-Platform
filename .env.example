COMPOSE_PROJECT_NAME=edutwin

# Database
MYSQL_DATABASE=edutwin
MYSQL_USER=edutwin_user
MYSQL_PASSWORD=edutwin_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3307

# Ports
API_PORT=5000
WEB_PORT=3000
ADMINER_PORT=8080

# API Settings
ConnectionStrings__Default=Server=mysql;Port=3306;Database=edutwin;User=edutwin_user;Password=edutwin_password;
Jwt__SigningKey=YOUR_DEVELOPMENT_SIGNING_KEY_HERE
Jwt__Issuer=EduTwinAuth
Jwt__Audience=EduTwinUsers
Gemini__ApiKey=YOUR_GEMINI_API_KEY
Gemini__Model=gemini-2.5-flash
Logging__LogLevel__Default=Information

# Health Checks
HealthChecks__MySqlHost=mysql
HealthChecks__MySqlPort=3306

# Frontend Configuration
# Lưu ý: P02 không cần cấu hình VITE_API_BASE_URL.
# Frontend sử dụng same-origin path /api/v1.
# Nginx sẽ làm nhiệm vụ reverse proxy đường dẫn /api/ tới http://api:8080/api/.

ASPNETCORE_ENVIRONMENT=Development
Seed__Enabled=true
Seed__CenterManagerPassword=change_me_to_a_secure_seed_password
